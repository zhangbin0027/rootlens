{
  "permissions": {
    "allow": [
      "Bash(python3 *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git status)",
      "Bash(git push *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Read(*)",
      "Edit(*)",
      "Write(*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 benchmarks/evaluate.py 2>&1 | grep -E 'Accuracy|False Blame|ZERO|TARGET|mismatches'"
          }
        ]
      }
    ]
  }
}
