{
  "permissions": {
    "allow": [
      "Bash(python3 *)",
      "Bash(git *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(cat *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(chmod *)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(which *)",
      "Bash(bash *)",
      "Bash(sh *)",
      "Read(*)",
      "Edit(*)",
      "Write(*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 benchmarks/evaluate.py 2>&1 | grep -E 'Accuracy|False Blame|ZERO|TARGET|mismatches'"
          }
        ]
      }
    ]
  }
}
