{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Edit(*)",
      "Write(*)"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(rm)",
      "Bash(rmdir *)",
      "Bash(rmdir)",
      "Bash(kill *)",
      "Bash(kill)",
      "Bash(pkill *)",
      "Bash(killall *)",
      "Bash(dd *)",
      "Bash(mkfs*)",
      "Bash(truncate *)",
      "Bash(shred *)",
      "Bash(wipefs *)",
      "Bash(fdisk *)",
      "Bash(parted *)",
      "Bash(sudo rm *)",
      "Bash(sudo kill *)",
      "Bash(sudo dd *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 benchmarks/evaluate.py 2>&1 | grep -E 'Accuracy|False Blame|ZERO|TARGET|mismatches'"
          }
        ]
      }
    ]
  }
}
