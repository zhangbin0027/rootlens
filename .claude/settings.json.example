{
  "permissions": {
    "allow": [
      "Bash(python3 *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(git *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(cut *)",
      "Bash(awk *)",
      "Bash(sed *)",
      "Bash(tee *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(touch *)",
      "Bash(chmod *)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(which *)",
      "Bash(bash *)",
      "Bash(sh *)",
      "Bash(pwd)",
      "Bash(pwd *)",
      "Bash(cd *)",
      "Bash(export *)",
      "Bash(env)",
      "Bash(env *)",
      "Bash(source *)",
      "Bash(. *)",
      "Bash(claude *)",
      "Bash(uname *)",
      "Bash(date *)",
      "Bash(time *)",
      "Bash(test *)",
      "Bash([ *)",
      "Bash([[ *)",
      "Read(*)",
      "Edit(*)",
      "Write(*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 benchmarks/evaluate.py 2>&1 | grep -E 'Accuracy|False Blame|ZERO|TARGET|mismatches'"
          }
        ]
      }
    ]
  }
}
